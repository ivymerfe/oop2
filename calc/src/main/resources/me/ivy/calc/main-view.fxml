<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.VBox?>
<?import atlantafx.base.controls.Card?>

<?import javafx.scene.layout.HBox?>
<VBox xmlns:fx="http://javafx.com/fxml" spacing="2" fx:controller="me.ivy.calc.CalculatorApp">
    <SplitPane orientation="VERTICAL" dividerPositions="0.4" VBox.vgrow="ALWAYS">
        <SplitPane dividerPositions="0.5">
            <Card>
                <header>
                    <Label text="Стек"/>
                </header>
                <body>
                    <ListView fx:id="stackView"/>
                </body>
            </Card>
            <Card>
                <header>
                    <Label text="Переменные"/>
                </header>
                <body>
                    <ListView fx:id="paramView"/>
                </body>
            </Card>
        </SplitPane>
        <Card>
            <header>
                <Label text="Консоль"/>
            </header>
            <body>
                <HBox spacing="5">
                    <TextArea fx:id="inputArea" wrapText="true" promptText="Введите программу...&#10;Shift+Enter для выполнения" HBox.hgrow="ALWAYS"/>
                    <TextArea fx:id="historyArea" wrapText="true" editable="false" HBox.hgrow="ALWAYS"/>
                </HBox>
            </body>
        </Card>
    </SplitPane>

</VBox>
