<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="640.0" prefWidth="980.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="labs.network.client.AppController">
    <top>
        <VBox spacing="8.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
            </padding>
            <VBox spacing="8.0">
                <GridPane hgap="8.0" vgap="8.0">
                    <Label text="Хост" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <TextField fx:id="hostField" promptText="localhost" prefWidth="180.0" GridPane.columnIndex="1"
                               GridPane.rowIndex="0"/>
                    <Label text="Порт" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                    <TextField fx:id="portField" promptText="6666" prefWidth="100.0" GridPane.columnIndex="3"
                               GridPane.rowIndex="0"/>

                    <Label text="Ник" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <TextField fx:id="nameField" promptText="nickname" prefWidth="180.0" GridPane.columnIndex="1"
                               GridPane.rowIndex="1"/>
                    <Label text="Пароль" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
                    <TextField fx:id="passField" promptText="password" prefWidth="180.0" GridPane.columnIndex="3"
                               GridPane.rowIndex="1"/>
                    <Label text="Название клиента" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                    <TextField fx:id="clientTypeField" promptText="clie1" prefWidth="180.0" GridPane.columnIndex="1"
                               GridPane.rowIndex="2"/>
                    <Label text="Serializer" GridPane.columnIndex="2" GridPane.rowIndex="2"/>
                    <ChoiceBox fx:id="serializerChoice" prefWidth="140.0" GridPane.columnIndex="3"
                               GridPane.rowIndex="2"/>
                </GridPane>
                <HBox spacing="8.0" alignment="CENTER_LEFT">
                    <Button fx:id="connectButton" mnemonicParsing="false" onAction="#connect" text="Подкл"/>
                    <Button fx:id="disconnectButton" mnemonicParsing="false" onAction="#disconnect" text="Откл"/>
                    <Button fx:id="refreshUsersButton" mnemonicParsing="false" onAction="#refreshUsers"
                            text="Список пользователей"/>
                    <Label fx:id="statusLabel" text="Отключен"/>
                </HBox>
            </VBox>
        </VBox>
    </top>
    <center>
        <SplitPane dividerPositions="0.74" BorderPane.alignment="CENTER">
            <VBox spacing="6.0">
                <padding>
                    <Insets bottom="10.0" left="10.0" right="10.0" top="0.0"/>
                </padding>
                <Label text="Messages"/>
                <ListView fx:id="messagesList" VBox.vgrow="ALWAYS"/>
                <HBox spacing="8.0">
                    <TextField fx:id="messageField" onAction="#sendMessage" promptText="Пиши сообщение"
                               HBox.hgrow="ALWAYS"/>
                    <Button fx:id="sendButton" mnemonicParsing="false" onAction="#sendMessage" text="Send"/>
                </HBox>
            </VBox>
            <VBox spacing="6.0">
                <padding>
                    <Insets bottom="10.0" left="10.0" right="10.0" top="0.0"/>
                </padding>
                <Label text="Users"/>
                <ListView fx:id="usersList" VBox.vgrow="ALWAYS"/>
            </VBox>
        </SplitPane>
    </center>
</BorderPane>
