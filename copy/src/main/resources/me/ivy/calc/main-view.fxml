<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import atlantafx.base.controls.Card?>

<VBox xmlns:fx="http://javafx.com/fxml" spacing="2" fx:controller="me.ivy.calc.CalculatorApp">
    <SplitPane orientation="VERTICAL" dividerPositions="0.4" VBox.vgrow="ALWAYS">
        <SplitPane dividerPositions="0.5">
            <Card>
                <header>
                    <Label text="Стек"/>
                </header>
                <body>
                    <ListView fx:id="stackView"/>
                </body>
            </Card>
            <Card>
                <header>
                    <Label text="Переменные"/>
                </header>
                <body>
                    <ListView fx:id="paramView"/>
                </body>
            </Card>
        </SplitPane>
        <VBox spacing="5">
            <Card VBox.vgrow="ALWAYS">
                <header>
                    <Label text="Консоль"/>
                </header>
                <body>
                    <HBox spacing="5" VBox.vgrow="ALWAYS">
                        <TextArea fx:id="inputArea" wrapText="true" promptText="Введи программу...&#10;Alt+Enter для выполнения" HBox.hgrow="ALWAYS"/>
                        <TextArea fx:id="historyArea" wrapText="true" editable="false" HBox.hgrow="ALWAYS"/>
                    </HBox>
                </body>
            </Card>
            <HBox spacing="10" style="-fx-padding: 5;">
                <Button text="Сохранить" onAction="#handleSave"/>
                <Button text="Загрузить" onAction="#handleLoad"/>
                <Button text="Выполнить" onAction="#handleRunProgram"/>
            </HBox>
        </VBox>
    </SplitPane>

</VBox>
